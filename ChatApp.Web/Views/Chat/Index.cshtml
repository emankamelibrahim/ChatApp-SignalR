@model ChatApp.Web.Models.ChatViewModel
@{
    ViewData["Title"] = "Chat";
}

<div class="container mt-4">
    <h3>Welcome, @Model.CurrentUserName</h3>

    <div class="row">

        <div class="col-md-6 border-end">
            <h5>Create Room</h5>
            <input type="text" id="roomNameInput" class="form-control mb-2" placeholder="Room name" />

            <div id="memberCheckboxList" class="mb-2">
                @foreach (var u in Model.OtherUsers)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input member-checkbox" value="@u.Id" id="member-@u.Id" />
                        <label class="form-check-label" for="member-@u.Id">@u.Email</label>
                    </div>
                }
            </div>

            <button id="createRoomBtn" class="btn btn-primary mb-4">Create Room</button>

            <h5>Your Rooms</h5>
            <select id="roomSelect" class="form-select mb-2">
                @foreach (var r in Model.Rooms)
                {
                    <option value="@r.Id" data-creator="@r.CreatedByUserId">@r.Name</option>
                }
            </select>
            <button id="deleteRoomBtn" class="btn btn-danger mb-4">Delete Room</button>
        </div>

        <div class="col-md-6">
            <h5>Send Room Message</h5>
            <input type="text" id="roomMessageInput" class="form-control mb-2" placeholder="Message" />
            <button id="sendRoomMessageBtn" class="btn btn-secondary mb-4">Send to Room</button>

            <h5>Send Private Message</h5>
            <select id="userSelect" class="form-select mb-2">
                @foreach (var u in Model.OtherUsers)
                {
                    <option value="@u.Id">@u.Email</option>
                }
            </select>
            <input type="text" id="privateMessageInput" class="form-control mb-2" placeholder="Message" />
            <button id="sendPrivateMessageBtn" class="btn btn-secondary mb-4">Send Private</button>
        </div>
    </div>

    <hr />

    <h5>Activity Feed</h5>
    <div id="activityFeed" style="height: 300px; overflow-y: scroll; border: 1px solid #ccc; padding: 10px;"></div>
</div>

<script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
<script>
    const currentUserId = "@Model.CurrentUserId";
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

    function logActivity(message) {
        const feed = document.getElementById("activityFeed");
        feed.innerHTML += `<div>${message}</div>`;
        feed.scrollTop = feed.scrollHeight;
    }

    function updateDeleteButtonState() {
        const select = document.getElementById("roomSelect");
        const deleteBtn = document.getElementById("deleteRoomBtn");
        const selected = select.options[select.selectedIndex];
        deleteBtn.disabled = !selected || selected.dataset.creator !== currentUserId;
    }

    document.getElementById("roomSelect").addEventListener("change", updateDeleteButtonState);


    connection.on("ReceiveActivity", (message) => {
        logActivity(message);
    });

    connection.on("ReceiveRoomMessage", (roomId, senderName, content) => {
        const select = document.getElementById("roomSelect");
        const option = [...select.options].find(o => o.value === roomId.toString());
        const roomName = option ? option.textContent : `Room ${roomId}`;
        logActivity(`[Room: ${roomName}] ${senderName}: ${content}`);
    });

    connection.on("ReceivePrivateMessage", (senderName, content) => {
        logActivity(`[Private] ${senderName}: ${content}`);
    });
    connection.on("RoomCreated", (roomId, roomName, creatorUserId) => {
        const select = document.getElementById("roomSelect");
        const option = document.createElement("option");
        option.value = roomId;
        option.textContent = roomName;
        option.dataset.creator = creatorUserId;
        select.appendChild(option);
        select.value = roomId; 
        updateDeleteButtonState();

        connection.invoke("JoinRoomGroup", roomId)
            .catch(err => logActivity(`Error joining room group: ${err}`));
    });

    connection.on("RoomDeleted", (roomId) => {
        const select = document.getElementById("roomSelect");
        const option = [...select.options].find(o => o.value === roomId.toString());
        if (option) option.remove();
        updateDeleteButtonState();
    });

    connection.start()
        .then(() => {
            logActivity("Connected.");
            updateDeleteButtonState();
        })
        .catch(err => logActivity(`Connection error: ${err}`));



    document.getElementById("createRoomBtn").addEventListener("click", () => {
        const name = document.getElementById("roomNameInput").value.trim();
        if (!name) return;

        const memberIds = [...document.querySelectorAll(".member-checkbox:checked")]
            .map(cb => cb.value);

        connection.invoke("CreateRoom", name, memberIds)
            .catch(err => logActivity(`Error creating room: ${err}`));

        document.getElementById("roomNameInput").value = "";
    });

    document.getElementById("deleteRoomBtn").addEventListener("click", () => {
        const select = document.getElementById("roomSelect");
        const roomId = parseInt(select.value);
        if (!roomId) return;

        connection.invoke("DeleteRoom", roomId)
            .catch(err => logActivity(`Error deleting room: ${err}`));
    });

    document.getElementById("sendRoomMessageBtn").addEventListener("click", () => {
        const select = document.getElementById("roomSelect");
        const roomId = parseInt(select.value);
        const input = document.getElementById("roomMessageInput");
        const content = input.value.trim();
        if (!roomId || !content) return;

        connection.invoke("SendRoomMessage", roomId, content)
            .catch(err => logActivity(`Error sending room message: ${err}`));

        input.value = "";
    });

    document.getElementById("sendPrivateMessageBtn").addEventListener("click", () => {
        const select = document.getElementById("userSelect");
        const recipientId = select.value;
        const input = document.getElementById("privateMessageInput");
        const content = input.value.trim();
        if (!recipientId || !content) return;

        connection.invoke("SendPrivateMessage", recipientId, content)
            .catch(err => logActivity(`Error sending private message: ${err}`));

        input.value = "";
    });
</script>